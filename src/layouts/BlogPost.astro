---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import TagLink from "../components/TagLink.astro";

type BlogPostData = CollectionEntry<"blog">["data"];
type BlogPostEntry = CollectionEntry<"blog">;
type Props = BlogPostData & {
  readTimeText: string;
  olderPost?: BlogPostEntry;
  newerPost?: BlogPostEntry;
  relatedPosts?: BlogPostEntry[];
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroImageAlt,
  tags,
  readTimeText,
  olderPost,
  newerPost,
  relatedPosts = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = heroImage ?? "/otter.webp";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  mainEntityOfPage: canonicalURL,
  url: canonicalURL,
  image: [new URL(typeof ogImage === "string" ? ogImage : ogImage.src, Astro.site).toString()],
  keywords: tags,
};
const updatedDateText = updatedDate?.toLocaleDateString("en-us", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

---

<html lang="en" class="dark">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={ogImage}
      imageAlt={heroImageAlt}
      ogType="article"
      publishedTime={pubDate}
      modifiedTime={updatedDate ?? pubDate}
      tags={tags}
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="w-full max-w-screen-md mx-auto my-4 dark:bg-neutral-800 dark:text-neutral-300 transition-colors duration-300">
    <Header />
    <main>
      <article class="px-4 ">
        <div class="flex justify-between mb-6">
          <div class="flex flex-col gap-1">
            <FormattedDate date={pubDate} />
            {
              updatedDate && (
                <p class="text-gray-500 dark:text-neutral-400 text-xs font-medium tracking-wide">
                  Updated {updatedDateText}
                </p>
              )
            }
          </div>
          <p class="text-gray-500 dark:text-neutral-400 text-xs font-medium tracking-wide">
            {readTimeText}
          </p>
        </div>
        <h1 class="text-5xl mb-8">
          {title}
        </h1>
        <div>
          {
            heroImage && (
              <img
                src={heroImage.src}
                width={1020}
                height={510}
                loading="eager"
                alt={heroImageAlt ?? `Cover image for ${title}`}
              />
            )
          }
        </div>
        <div class="mt-10">
          <slot />
        </div>
        <div>
          {
            tags && (
                <ul class="flex gap-2">
                  {tags.map((tag) => (
                    <li>
                      <TagLink tag={tag} />
                    </li>
                  ))}
                </ul>
            )
          }
        </div>
        {
          (newerPost || olderPost) && (
            <nav class="mt-10 pt-8 border-t border-neutral-200 dark:border-neutral-700">
              <h2 class="text-xl font-bold mb-4">Continue reading</h2>
              <div class="grid gap-3 sm:grid-cols-2">
                {
                  newerPost && (
                    <a class="border rounded-lg p-4 hover:no-underline hover:bg-neutral-100 dark:border-neutral-700 dark:hover:bg-neutral-700/30 transition-colors" href={`/blog/${newerPost.id}`}>
                      <p class="text-xs mb-2 text-neutral-500 dark:text-neutral-400">Newer post</p>
                      <p class="font-semibold">{newerPost.data.title}</p>
                    </a>
                  )
                }
                {
                  olderPost && (
                    <a class="border rounded-lg p-4 hover:no-underline hover:bg-neutral-100 dark:border-neutral-700 dark:hover:bg-neutral-700/30 transition-colors" href={`/blog/${olderPost.id}`}>
                      <p class="text-xs mb-2 text-neutral-500 dark:text-neutral-400">Older post</p>
                      <p class="font-semibold">{olderPost.data.title}</p>
                    </a>
                  )
                }
              </div>
            </nav>
          )
        }
        {
          relatedPosts.length > 0 && (
            <section class="mt-10 pt-8 border-t border-neutral-200 dark:border-neutral-700">
              <h2 class="text-xl font-bold mb-4">Related posts</h2>
              <ul class="grid gap-3 sm:grid-cols-3">
                {relatedPosts.map((relatedPost) => (
                  <li>
                    <a class="block border rounded-lg p-4 hover:no-underline hover:bg-neutral-100 dark:border-neutral-700 dark:hover:bg-neutral-700/30 transition-colors h-full" href={`/blog/${relatedPost.id}`}>
                      <p class="font-semibold">{relatedPost.data.title}</p>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )
        }
      </article>
    </main>
    <script src="https://giscus.app/client.js" is:inline
            data-repo="elliott-diy/elliott-diy"
            data-repo-id="R_kgDONWVN1g"
            data-category="Announcements"
            data-category-id="DIC_kwDONWVN1s4CqAS0"
            data-mapping="pathname"
            data-strict="0"
            data-reactions-enabled="1"
            data-emit-metadata="0"
            data-input-position="bottom"
            data-theme="light"
            data-lang="en"
            crossorigin="anonymous"
            async>
    </script>
    <Footer />
  </body>
<style is:inline>
      /* Base Styles */
  img {
      max-width: 100%;
      height: auto;
      display: block;
      margin: 20px 0;
  }

  /* Headings */
  h1, h2, h3, h4, h5, h6 {
      color: var(--grey-900);
      margin-top: 24px;
      margin-bottom: 16px;
      font-weight: bold;
  }

  h1 { font-size: 32px; }
  h2 { font-size: 28px; }
  h3 { font-size: 24px; }
  h4 { font-size: 20px; }
  h5 { font-size: 18px; }
  h6 { font-size: 16px; }

  /* Paragraphs */
  p {
      margin-top: 0;
      margin-bottom: 16px;
  }

  /* Blockquotes */
  blockquote {
      border-left: 4px solid #ccc;
      padding: 10px 20px;
      margin: 20px 0;
      color: #666;
      background-color: #f9f9f9;
      @apply dark:bg-neutral-700 text-white border-l-4 border-neutral-500;
  }

  /* Code Blocks and Inline Code */

  pre {
      padding: 10px;
      overflow-x: auto;
      margin-top: 0;
      margin-bottom: 16px;
  }


  code {
      padding: 2px 4px;
      font-family: 'Courier New', monospace;
      font-size: 90%;
  }

  /* Fix tables on mobile */
  article table {
    border-collapse: collapse;
    min-width: 100%;
  }

  article table th,
  article table td {
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    article table {
      display: block;
      overflow-x: auto;
      max-width: 100%;
      -webkit-overflow-scrolling: touch;
    }
  }



  /* Tables */
  table {
      width: 100%;
      margin-bottom: 20px;
      border-collapse: collapse;
  }

  th, td {
      padding: 8px;
      border: 1px solid #ddd;
  }
  th {
      background-color: #f4f4f4;
      @apply dark:bg-neutral-700;
  }
  th {
      background-color: var(--neutral-200, #f4f4f4);
      color: var(--neutral-900, #000);
      }

  html.dark th {
      background-color: var(--neutral-700, #333);
      color: var(--neutral-100, #fff);
      }

  /* Lists */
  .footnotes ul, ol {
      margin-top: 0;
      margin-bottom: 16px;
      padding-left: 20px;
      list-style: outside;
  }

  /* Special HTML Tags */
  abbr {
      border-bottom: 1px dotted #666;
      cursor: help;
  }

  kbd {
      padding: 2px 4px;
      font-size: 90%;
      color: #fff;
      background-color: #333;
      border-radius: 3px;
  }

  mark {
      background-color: yellow;
      color: black;
  }

  sup, sub {
      font-size: 75%;
      line-height: 0;
      position: relative;
      vertical-align: baseline;
  }

  sup { top: -0.5em; }
  sub { bottom: -0.25em; }




</style>


</html>
