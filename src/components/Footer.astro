---
import { Icon } from "astro-iconify";

const today = new Date();
---

<footer class="mt-20 md:mt-36 mx-4">
  <div class="flex gap-4 border-b pb-8 mb-5 flex-col lg:flex-row  ">
    <div class="w-full lg:w-2/3">
      <h1 class="text-lg font-bold">Elliott.diy</h1>
      <p class="text-sm">
          Powered by curiosity, coffee, and a bunch of half-finished ideas that somehow made it online.
      </p>
	  <div class="flex gap-3 mt-3">
		<a href="https://discord.com/users/559055812438392834" target="_blank" rel="noopener noreferrer">
			<Icon name="radix-icons:discord-logo" class="w-5 h-5 text-gray-600 hover:text-gray-500 dark:text-neutral-200"/>
		</a>
		<a href="https://www.github.com/elliott-diy" target="_blank" rel="noopener noreferrer">
			<Icon name="radix-icons:github-logo" class="w-5 h-5 text-gray-600 hover:text-gray-500 dark:text-neutral-200"/>
		</a>
		<a href="mailto:hey@elliott.diy" target="_blank" rel="noopener noreferrer">
			<Icon name="radix-icons:envelope-closed" class="w-5 h-5 text-gray-600 hover:text-gray-500 dark:text-neutral-200"/>
		</a>
		
	  </div>
    </div>
    <div class="flex lg:ml-auto gap-10 mt-1">
      <div>
        <h1 class="font-bold mb-3 text-base">
          Pages
        </h1>
        <ul class="flex flex-col gap-2 text-sm">
            <li>
                <a href="/about" class="flex items-center gap-1 hover:underline">About <Icon name="radix-icons:arrow-top-right" class="w-3 h-3" /></a>
            </li>
          <li>
              <a href="/blog" class="flex items-center gap-1 hover:underline">Blog <Icon name="radix-icons:arrow-top-right" class="w-3 h-3" /></a>			</li>
			<li>
				<a href="/projects" class="flex items-center gap-1 hover:underline">Projects <Icon name="radix-icons:arrow-top-right" class="w-3 h-3" /></a>
			</li>
        </ul>
      </div>
    </div>
  </div>
  <p class="text-sm font-medium mb-10">
    &copy; {today.getFullYear()} Elliott. All rights reserved.
  </p>
</footer>
<script is:inline defer src="https://track.elliott.diy/script.js" data-website-id="b3d8f430-7d09-4f3a-b670-b56a508562d7" type="text/javascript"></script>
