---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE } from "../../consts";
import { getCollection, type CollectionEntry } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import TagLink from "../../components/TagLink.astro";

type Post = CollectionEntry<'blog'>;

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const postByYear: {
  [year: number]: Post[];
} = {}

posts.forEach((post) => {
  const year = post.data.pubDate.getFullYear()
  if (!postByYear[year]) {
    postByYear[year] = []
  }
  postByYear[year].push(post)
})
---

<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description="Writeups, debugging adventures, and experiments. If it broke my brain or made me curious, it probably ended up here." />
  </head>
  <body class="w-full  mx-auto my-4 max-w-screen-md dark:bg-neutral-800 dark:text-neutral-300 transition-colors duration-300">
    <Header />
    <section class="px-4 pt-8 pb-6 max-w-screen-md mx-auto">
      <h1 class="text-3xl font-bold mb-3">Blog Posts</h1>
      <p class="text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
        A collection of writeups, debugging adventures, and technical experiments. If it broke my brain or made me curious, it probably ended up here.
      </p>
    </section>
    <main
      class="w-full max-w-screen-md mx-auto my-4 px-4 flex flex-col gap-4 justify-center"
    >
      {
        Object.keys(postByYear).sort(
          (a, b) => parseInt(b) - parseInt(a)
        ).map((year) => (
          <div class="flex flex-col">
            <h2 class=" text-black dark:text-white font-bold mb-8">{year}</h2>
            <div class="flex flex-col gap-4">
              
            {
              postByYear[parseInt(year)].map((post: Post) => (
              <div class="flex gap-4 items-start border-b pb-4">
            <div class="flex flex-col gap-4 flex-1 min-w-0">
              <FormattedDate date={post.data.pubDate} />
              <a class="font-bold text-lg min-w-0 break-words" href={`/blog/${post.id}`}>
                {post.data.title}
              </a>
              <p class="text-gray-500 dark:text-neutral-400 text-base font-medium tracking-wide break-words">
                {post.data.description}
              </p>
              <div class="flex gap-2">
                {post.data.tags?.map((i: string) => {
                  return <TagLink tag={i} />;
                })}
              </div>
            </div>
            {
              post.data.heroImage ? (
                <a href={`/blog/${post.id}`} class="hidden sm:block sm:flex-shrink-0 sm:ml-2">
                  <img
                    src={post.data.heroImage.src}
                    alt={post.data.heroImageAlt ?? `Cover image for ${post.data.title}`}
                    width={160}
                    height={96}
                    loading="lazy"
                    class="w-40 h-24 object-cover border border-gray-200 rounded-sm"
                  />
                </a>
              ) : null
            }
          </div>
              ))
            }
            </div>

          </div>
        ))
      }
    </main>
    <Footer />
  </body>
</html>
